{
  "name": "sdk-php-ingestao-vetorial",
  "description": "Standalone PHP 8.2 SDK for the Ingestão Vetorial API — Guzzle-based, Laravel-compatible.",
  "type": "library",
  "homepage": "https://github.com/ezequiel88/sdk-php-ingestao-vetorial",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12"
  },
  "autoload": {
    "psr-4": {
      "IngestaoVetorial\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IngestaoVetorial\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist"
  },
  "support": {
    "source": "https://github.com/ezequiel88/sdk-php-ingestao-vetorial",
    "issues": "https://github.com/ezequiel88/sdk-php-ingestao-vetorial/issues"
  }
}
